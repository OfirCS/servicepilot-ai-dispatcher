# Public browser config
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only Supabase service role for Netlify Functions
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SERVICEPILOT_COMPANY_ID=00000000-0000-4000-8000-000000000001

# Twilio SMS and call forwarding
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
OWNER_PHONE_NUMBER=
FORWARD_TO_NUMBER=

# Optional AI provider for live intake. Without this, deterministic local classification is used.
OPENAI_API_KEY=

# Demo safety switch. Leave true for local demos without sending real SMS.
SERVICEPILOT_DEMO_MODE=true
